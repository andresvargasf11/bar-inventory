# Turso Database
# For local development: TURSO_DATABASE_URL=file:./dev.db (no auth token needed)
# For production: use your Turso database URL and auth token
TURSO_DATABASE_URL=file:./dev.db
TURSO_AUTH_TOKEN=

# Session secret - change this to a random 32+ character string in production
SESSION_SECRET=change-this-to-a-random-32-character-string
